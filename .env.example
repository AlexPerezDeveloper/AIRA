# AI Requirements Architect - Environment Variables
# Copiar a .env y completar con tus valores

# Azure Speech Services (requerido)
# Obtén en: https://portal.azure.com/ -> Speech Services -> Keys and Endpoint
AZURE_SPEECH_KEY=tu_azure_speech_key_aqui
AZURE_SPEECH_REGION=westeurope

# Ollama (opcional - defaults a localhost)
OLLAMA_URL=http://localhost:11434

# Configuración de análisis (opcional)
ANALYSIS_INTERVAL_SECONDS=30

# Configuración de dispositivo de audio (opcional - auto-detecta si no está)
# macOS: BlackHole 2ch
# Windows: CABLE Output (VB-Audio Virtual Cable)
# AUDIO_DEVICE_NAME=BlackHole 2ch
